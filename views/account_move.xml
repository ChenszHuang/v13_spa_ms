<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_tree_inherit" model="ir.ui.view">
        <field name="name">account.move.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_residual_signed']" position="after">
                <field name="invoice_payment_state"/>
            </xpath>
        </field>
    </record>

    <record id="action_spa_invoice" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">account.move</field>
        <field name="domain">[('type', '=', 'out_invoice')]</field>
        <field name="context">{'default_type': 'out_invoice', 'journal_type': 'sale'}</field>
    </record>
</odoo>