<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_tree_inherit" model="ir.ui.view">
        <field name="name">account.move.tree.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_residual_signed']" position="after">
                <field name="invoice_payment_state"/>
            </xpath>
        </field>
    </record>

    <record id="view_invoice_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@id='aml_tab']" position="after">
                <page id="payment_tab" string="Payments">
                    <field name="payment_ids">
                        <tree>
                            <field name="payment_date"/>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="amount"/>
                            <field name="state"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_spa_invoice" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">account.move</field>
        <field name="domain">[('type', '=', 'out_invoice')]</field>
        <field name="context">{'default_type': 'out_invoice', 'journal_type': 'sale'}</field>
    </record>
</odoo>