<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_therapist_tree" model="ir.ui.view">
        <field name="name">spa.therapist.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree string="Therapist">
                <field name="number" />
                <field name="therapist_code" />
                <field name="name" />
                <field name="mobile" />
                <field name="phone" />
                <field name="email" />
            </tree>
        </field>
    </record>

    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="replace">
                <form string="Partners">
                    <header>
                        <button type="object" class="oe_stat_button" icon="fa-pencil-square-o"
                            name="action_view_partner_invoices"
                            context="{'default_partner_id': active_id}">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_value">
                                    <field name="total_invoiced" widget="monetary"
                                        options="{'currency_field': 'currency_id'}" />
                                </span>
                                <span class="o_stat_text">Invoiced</span>
                            </div>
                        </button>
                    </header>

                    <sheet>
                        <widget name="web_ribbon" text="Archived" bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}" />

                        <field name="image_1920" widget="image" class="oe_avatar"
                            options="{'preview_image': 'image_128'}"
                            help="Square image recommended. Max 1920px." />

                        <div class="oe_title">
                            <field name="id" invisible="1" />
                            <field name="active" invisible="1" />
                            <field name="type" invisible="1" />

                            <field name="company_type" widget="radio" class="oe_edit_only"
                                options="{'horizontal': true}" />


                            <h1 style="max-width: 90%;">
                                <field name="name" default_focus="1" placeholder="Name"
                                    attrs="{'required': [('type', '=', 'contact')]}" />
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="is_therapist" invisible="1" />
                                <field name="type" invisible="1" />
                                <field name="parent_id" invisible="1" />
                                <field name="number"
                                    attrs="{'invisible': [('is_therapist','=', False)]}"
                                    force_save="1" />
                                <field name="nickname" />
                                <field name="birthday" />
                                <field name="gender" />
                                <field name="marital" />

                                <field name="type" attrs="{'invisible': [('parent_id','=', False)]}"
                                    groups="base.group_no_one" />
                                <label for="street" string="Address" />
                                <div class="o_address_format">
                                    <div
                                        attrs="{'invisible': ['|', ('parent_id', '=', False), ('type', '!=', 'contact')]}"
                                        class="oe_edit_only">
                                        <b>Company Address:</b>
                                    </div>
                                    <field name="street" placeholder="Street..."
                                        class="o_address_street"
                                        attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}" />
                                    <field name="street2" placeholder="Street 2..."
                                        class="o_address_street"
                                        attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}" />
                                    <field name="city" placeholder="City" class="o_address_city"
                                        attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}" />
                                    <field name="state_id" class="o_address_state"
                                        placeholder="State" options='{"no_open": True}'
                                        attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"
                                        context="{'country_id': country_id, 'zip': zip}" />
                                    <field name="zip" placeholder="ZIP" class="o_address_zip"
                                        attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}" />
                                    <field name="country_id" placeholder="Country"
                                        class="o_address_country"
                                        options='{"no_open": True, "no_create": True}'
                                        attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}" />
                                </div>
                            </group>

                            <group>

                                <field name="phone" />
                                <field name="mobile" />
                                <field name="email" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Other Info"
                                attrs="{'invisible':[('is_therapist', '=', False)]}">
                                <group col="4">
                                    <field name="therapist_code" colspan="2" />
                                    <field name="join_date" colspan="2" />
                                    <field name="therapist_type" />
                                </group>
                            </page>
                            <page name='internal_notes' string="Internal Notes">
                                <field name="comment" placeholder="Internal note..." />
                            </page>
                            <page string="Settings">
                                <group col="4">
                                    <field name="is_therapist" colspan="2" />
                                    <field name="is_guide" colspan="2" />
                                </group>
                                <group string="Commissions" colspan="4">
                                    <label for="commission_ids" />
                                    <newline />
                                        <field name="commission_ids" nolabel="1" context="{'default_partner_id': active_id}">>
                                            <tree editable="bottom">
                                                <field name="partner_id" invisible="1" />
                                                <field name="product_id" />
                                                <field name="commission_type" />
                                                <field name="amount" />
                                            </tree>
                                        </field>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" />
                        <field name="message_ids" widget="mail_thread" />
                    </div>
                </form>
            </xpath>
        </field>
    </record>


    <record id="action_spa_therapist" model="ir.actions.act_window">
        <field name="name">Therapist</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_therapist','=',True)]</field>
        <field name="context">{'default_is_therapist': True}</field>
        <field name="view_id" ref="v13_spa_ms.view_therapist_tree" />
    </record>

    <record id="action_spa_guide" model="ir.actions.act_window">
        <field name="name">Guide</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_guide','=',True)]</field>
        <field name="context">{'default_is_guide': True}</field>
        <field name="view_id" ref="base.view_partner_tree" />
    </record>

</odoo>