<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="view_spa_order_tree" model="ir.ui.view">
        <field name="name">spa.order.tree</field>
        <field name="model">spa.order</field>
        <field name="arch" type="xml">
            <tree string="Spa Orders">
                <field name="id"/>
                <field name="partner_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_spa_order_form" model="ir.ui.view">
        <field name="name">spa.order.form</field>
        <field name="model">spa.order</field>
        <field name="arch" type="xml">
            <form string="Spa Order">
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="state" readonly="1"/>
                        <field name="invoice_id" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Sessions">
                            <field name="order_line_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="therapist_id"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>


    <record id="action_spa_order" model="ir.actions.act_window">
        <field name="name">Spa Orders</field>
        <field name="res_model">spa.order</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
