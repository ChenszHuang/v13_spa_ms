<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_spa_order_tree" model="ir.ui.view">
        <field name="name">spa.order.tree</field>
        <field name="model">spa.order</field>
        <field name="arch" type="xml">
            <tree string="Spa Orders">
                <field name="number"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="treatment_count" sum="Total Treatment"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_spa_order_form" model="ir.ui.view">
        <field name="name">spa.order.form</field>
        <field name="model">spa.order</field>
        <field name="arch" type="xml">
            <form string="Spa Order">
                <header>
                    <button name="action_waitlist" type="object" string="Set to Waitlist" class="btn btn-secondary" states="draft"/>
                    <button name="action_confirm" type="object" string="Confirm" confirm="Are you sure to confirm this order?" class="btn btn-primary" states="draft,wait"/>
                    <button name="action_cancel" type="object" string="Cancel" states="draft,wait,confirm"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,wait,confirm,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="number"/>
                        <h1>
                            <field name="number" placeholder="Number" force_save="1"/>
                        </h1>
                    </div>

                    <group col="4" colspan="2">
                        <field name="partner_id"/>
                        <field name="date"/>
                        <field name="reference"/>
                    </group>

                    <notebook>
                        <page string="Sessions">
                            <group>
                                <field name="treatment_count"/>
                            </group>
                            <group>
                                <label for="spa_session_ids" string="Treatment Sessions"/>
                                <newline/>
                                <field name="spa_session_ids" nolabel="1">
                                    <tree editable="bottom">
                                        <field name="product_id" context="{'tree_view_ref': 'v13_spa_ms.view_product_treatment_tree'}" width="23%"/>
                                        <field name="product_price" width="10%"/>
                                        <field name="start_time" width="15%"/>
                                        <field name="end_time" width="15%"/>
                                        <field name="discount" string="Disc%" width="12%"/>
                                        <field name="therapist_id" domain="[('is_therapist','=',True)]" width="15%"/>
                                        <field name="state" width="10%"/>
                                    </tree>
                                </field>
                            </group>
                        </page>

                        <page string="Invoicing">
                            <label for="invoice_ids" string="Invoices"/>
                            <field name="invoice_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="invoice_date_due"/>
                                    <field name="amount_total"/>
                                    <field name="amount_residual"/>
                                    <field name="invoice_payment_state"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <field name="display_name" invisible="1"/>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>


    <record id="action_spa_order" model="ir.actions.act_window">
        <field name="name">Spa Orders</field>
        <field name="res_model">spa.order</field>
        <field name="view_mode">tree,form</field>
        <field name="context">
            {}
        </field>
    </record>
</odoo>
