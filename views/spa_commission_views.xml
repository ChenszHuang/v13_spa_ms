<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_spa_commission_tree" model="ir.ui.view">
        <field name="name">spa.commission.tree</field>
        <field name="model">spa.commission</field>
        <field name="arch" type="xml">
            <tree string="Spa Commission">
                <field name="partner_id" />
                <field name="product_id" />
                <field name="commission_type" />
                <field name="amount" />
            </tree>
        </field>
    </record>

    <record id="view_spa_commission_form" model="ir.ui.view">
        <field name="name">spa.commission.form</field>
        <field name="model">spa.commission</field>
        <field name="arch" type="xml">
            <form string="Spa Commission">
                <sheet>
                    <group string="General Configuration">
                        <group>
                            <field name="partner_id" />
                            <field name="commission_type" />

                        </group>
                        <group>
                            <field name="product_id" />
                            <field name="amount" />
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>

    <record id="action_spa_commission" model="ir.actions.act_window">
        <field name="name">Spa Commission</field>
        <field name="res_model">spa.commission</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>