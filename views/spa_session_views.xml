<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_spa_session_tree" model="ir.ui.view">
        <field name="name">spa.session.tree</field>
        <field name="model">spa.session</field>
        <field name="arch" type="xml">
            <tree string="Spa Session">
                <field name="start_time" />
                <field name="end_time" />
                <field name="spa_order_id" />
                <field name="product_id" />
                <field name="duration" />
                <field name="product_price" sum="Subtotal" />
                <field name="discount" />
                <field name="total_amount" sum="Amount Total" />
                <field name="therapist_id" />
                <field name="state" />
            </tree>
        </field>
    </record>

    <record id="view_spa_session_form" model="ir.ui.view">
        <field name="name">spa.session.form</field>
        <field name="model">spa.session</field>
        <field name="arch" type="xml">
            <form string="Spa Session">
                <header>
                    <button name="action_waitlist" type="object" string="Set to Waitlist"
                        class="btn btn-primary" states="draft" />
                    <button name="action_start" type="object" string="Start" class="btn btn-primary"
                        states="wait" />
                    <button name="action_done" type="object" string="Finish" class="btn btn-primary"
                        states="ongoing" />
                    <button name="action_cancel" type="object" string="Cancel"
                        class="btn btn-secondary" attrs="{'invisible' : [('state', '=', 'cancel')]}" />
                    <button name="action_draft" type="object" string="Set to Draft"
                        class="btn btn-primary" states="cancel" />
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,wait,ongoing,done" />
                </header>
                <sheet>
                    <group col="4">
                        <group colspan="2">
                            <label for="datetime_begin" string="Start &amp; End Time" />
                            <div class="o_row">
                                <field name="start_time" nolabel="1" class="oe_inline"
                                    attrs="{'readonly' : [('state', '!=', 'draft')]}" />
                                <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon"
                                    title="Arrow" />
                                <field name="end_time" nolabel="1" class="oe_inline"
                                    attrs="{'readonly' : [('state', '!=', 'draft')]}" />
                            </div>
                        </group>
                    </group>
                    <group colspan="2">
                        <group>
                            <field name="therapist_id" />
                            <field name="product_id" />
                            <field name="product_price" force_save="1" />
                            <field name="duration" force_save="1" />
                        </group>
                        <group>
                            <field name="spa_order_id" />
                            <field name="partner_id" />
                            <field name="commission_amount" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Other Info">
                            <label for="remarks" />
                            <field name="remarks" />
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>

        </field>
    </record>


    <record id="view_spa_session_pivot" model="ir.ui.view">
        <field name="name">spa.session.pivot</field>
        <field name="model">spa.session</field>
        <field name="arch" type="xml">
            <pivot string="Therapist Pivot">
                <field name="therapist_id" type="row" />
                <field name="state" type="col" />
            </pivot>
        </field>
    </record>

    <record id="view_spa_session_search" model="ir.ui.view">
        <field name="name">spa.session.search</field>
        <field name="model">spa.session</field>
        <field name="arch" type="xml">
            <search string="Spa Session Search">
                <field name="spa_order_id" />
                <field name="product_id" />
                <field name="therapist_id" />
                <field name="state" />

                <filter string="Today" name="today_session"
                    domain="[
                    ('start_time', '&gt;=', datetime.date.today().strftime('%Y-%m-%d 00:00:00')),
                    ('start_time', '&lt;=', datetime.date.today().strftime('%Y-%m-%d 23:59:59'))
                ]" />

                <group expand="0" string="Group By">
                    <filter string="Therapist" name="therapist"
                        context="{'group_by': 'therapist_id'}" />
                    <filter string="Status" name="state" context="{'group_by': 'state'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_spa_session" model="ir.actions.act_window">
        <field name="name">Spa Sessions</field>
        <field name="res_model">spa.session</field>
        <field name="view_mode">tree,form,pivot</field>
        <field name="context">{'search_default_today_session': 1}</field>
    </record>
</odoo>