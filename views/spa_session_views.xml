<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_spa_session_tree" model="ir.ui.view">
        <field name="name">spa.session.tree</field>
        <field name="model">spa.session</field>
        <field name="arch" type="xml">
            <tree string="Spa Session">
                <field name="id"/>
                <field name="spa_order_id"/>
                <field name="product_id"/>
                <field name="therapist_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_spa_session_form" model="ir.ui.view">
        <field name="name">spa.session.form</field>
        <field name="model">spa.session</field>
        <field name="arch" type="xml">
            <form string="Spa Session">
                <sheet>
                    <group>
                        <field name="spa_order_id"/>
                        <field name="state" readonly="1"/>
                        <field name="therapist_id" />
                    </group>

                    <group>
                        <field name="start_time"/>
                        <field name="end_time"/>
                    </group>

                    <field name="unavailable_therapist_ids" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_spa_session" model="ir.actions.act_window">
        <field name="name">Spa Sessions</field>
        <field name="res_model">spa.session</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
