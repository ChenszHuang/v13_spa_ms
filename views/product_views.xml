<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Product Template view-->
    <record id="view_product_treatment_tree" model="ir.ui.view">
        <field name="name">product.template.treatment.tree</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <tree string="Treatments">
                <field name="treatment_code"/>
                <field name="name"/>
                <field name="treatment_type_id"/>
                <field name="duration"/>
                <field name="list_price"/>
            </tree>
        </field>
    </record>

    <record id="view_product_treatment_form" model="ir.ui.view">
        <field name="name">product.template.treatment.form</field>
        <field name="model">product.template</field>    
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="priority">999</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="replace">
                <form string="Treatments">
                    <sheet>
                        <field name="product_variant_count" invisible="1"/>
                        <field name="is_product_variant" invisible="1"/>
                        <field name="attribute_line_ids" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="active" invisible="1"/>
                        <div class="oe_button_box" name="button_box"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                        <field name="id" invisible="True"/>
                        <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                        <div class="oe_title">
                            <label class="oe_edit_only" for="name" string="Product Name"/>
                            <h1 style="max-width: 90%;">
                                <field name="name" default_focus="1" placeholder="Name"/>
                            </h1>
                            <div name="options" groups="base.group_user">
                                <div>
                                    <field name="sale_ok"/>
                                    <label for="sale_ok"/>
                                </div>
                                <div>
                                    <field name="purchase_ok"/>
                                    <label for="purchase_ok"/>
                                </div>
                            </div>
                        </div>

                        <notebook>
                            <page string="General Information" name="general_information">
                                <group col="4" colspan="2">
                                    <field name="treatment_code"/>
                                    <field name="duration"/>
                                    <field name="treatment_type_id"/>
                                    <field name="list_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </xpath>
        </field>
    </record>

    <!-- Treatment Type view -->

    <record id="view_treatment_type_tree" model="ir.ui.view">
        <field name="name">treatment.type.tree</field>
        <field name="model">treatment.type</field>
        <field name="arch" type="xml">
            <tree string="Treatment Type">
                <field name="code"/>
                <field name="name"/>
            </tree>
        </field>
    </record>


    <record id="view_treatment_type_form" model="ir.ui.view">
        <field name="name">treatment.type.form</field>
        <field name="model">treatment.type</field>
        <field name="arch" type="xml">
            <form string="Treatment Type">
                <sheet>
                    <div class="oe_title">
                            <field name="id" invisible="1" />
                         
                            <h1 style="max-width: 90%;">
                                    <field name="name"
                                        default_focus="1"
                                        placeholder="Name"/>
                            </h1>
                        </div>

                        <group col="4" >
                            <group colspan="2">
                                <field name="code"/>
                            </group>
                            
                        </group>
                        <group colspan="2">
                            <label for="treatment_ids"/> 
                            <newline/>
                            <field name="treatment_ids" nolabel="1" readonly="1"/>
                        </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_treatment" model="ir.actions.act_window">
        <field name="name">Treatments</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
			eval="[(5, 0, 0),
		(0, 0, {'view_mode': 'tree', 'view_id': ref('view_product_treatment_tree')}),
		(0, 0, {'view_mode': 'form', 'view_id': ref('view_product_treatment_form')})
		]" />
    </record>

    <record id="action_treatment_type" model="ir.actions.act_window">
        <field name="name">Treatment Type</field>
        <field name="res_model">treatment.type</field>
        <field name="view_mode">tree,form</field>
    </record>




</odoo>