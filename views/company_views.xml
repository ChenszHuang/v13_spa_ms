<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="ir.ui.view" id="view_company_form">
        <field name="name">view.company.form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[1]" position="after">
                <page string="Configuration">
                    <group col="4">
                        <group string="Accounting" colspan="2">
                            <field name="default_account_receivable"/>
                            <field name="default_account_payable"/>
                            <field name="default_property_account_income_id"/>
                            <field name="default_property_account_expense_id"/>
                            <field name="default_invoice_payment_term_id"/>
                        </group>
                        <group string="Journals" colspan="2">
                            <field name="default_invoice_journal_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>