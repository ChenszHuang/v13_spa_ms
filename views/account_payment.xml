<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_custom" model="ir.ui.view">
        <field name="name">account.payment.form.custom</field>
        <field name="model">account.payment</field>
        <field name="priority">0</field>
        <field name="arch" type="xml">
            <form string="Payment">
                <header>
                    <button name="post" type="object" string="Validate" states="draft" class="btn-primary"/>
                    <button name="action_cancel" type="object" string="Cancel" states="draft,posted"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted,reconciled,cancelled"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Number"/>
                        <h1>
                            <field name="name" force_save="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" invisible="1"/>
                            <field name="has_invoices" invisible="1"/>
                            <field name="hide_payment_method" invisible="1"/>
                            <field name="show_partner_bank_account" invisible="1"/>

                            <field name="payment_type"/>
                            <field name="partner_type"/>
                            <field name="partner_id"/>
                            <field name="amount"/>
                            <field name="currency_id"/>
                        </group>

                        <group>
                            <field name="journal_id"/>
                            <field name="payment_method_id" attrs="{'invisible': [('hide_payment_method','=',True)]}"/>
                            <field name="payment_date"/>
                            <field name="communication"/>
                        </group>
                    </group>

                    <notebook>

                        <!-- Invoices -->
                        <page string="Invoices" attrs="{'invisible': [('has_invoices','=',False)]}">
                            <field name="invoice_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="amount_total"/>
                                    <field name="invoice_date"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Journal Items -->
                        <page string="Journal Items">
                            <field name="move_line_ids" readonly="1">
                                <tree>
                                    <field name="account_id"/>
                                    <field name="debit"/>
                                    <field name="credit"/>
                                    <field name="partner_id"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Other Info -->
                        <page string="Other Info">
                            <group>
                                <field name="destination_account_id"/>
                                <field name="destination_journal_id" attrs="{'invisible': [('payment_type','!=','transfer')]}"/>
                                <field name="partner_bank_account_id" attrs="{'invisible': [('show_partner_bank_account','=',False)]}"/>
                            </group>

                            <group string="Difference Handling">
                                <field name="payment_difference"/>
                                <field name="payment_difference_handling"/>
                                <field name="writeoff_account_id" attrs="{'invisible': [('payment_difference_handling','!=','reconcile')]}"/>
                                <field name="writeoff_label"/>
                            </group>
                        </page>

                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_spa_payment" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">tree,form</field>
        <field name="context">
            {
                'default_payment_type': 'inbound',
                'default_partner_type': 'customer'
            }
        </field>
        <field name="domain"> [('payment_type','=','inbound'), ('partner_type','=','customer')]</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('account.view_account_payment_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('v13_spa_ms.view_account_payment_form_custom')})]"/>
    </record>
</odoo>