<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="report_receipt_compact_document">
            <t t-call="v13_spa_ms.internal_layout_compact">
                <t t-set="o" t-value="o.with_context(lang=lang)" />
                <t t-set="compact" t-value="True" />
                <t t-set="exclude_footer" t-value="True" />
                <style>
                    .cell_value {width: 33%; padding: 2px; white-space: nowrap; text-align: right;}
                    .border_top_black {border-top: 1px solid black}
                    .border_bottom_black {border-bottom: 1px solid black}
                    .border_bottom_grey {border-bottom: 1px solid #bbbbbb}
                </style>
                <div class="page" style="font-size: 10pt; font-family:'Sans-serif'">
                    <table style="width: 100%;" cellpadding="0" cellspacing="0">
                        <tr style="width: 100%; text-align: left; vertical-align: top;">
                            <td style="width: 32%; font-weight: bold;">
                                <span>Receipt No&amp;nbsp;</span>
                            </td>
                            <td style="width: 2%; font-weight: bold;">
                                <span>:</span>
                            </td>
                            <td style="width: 66%;">
                                <span t-if="o.name != '/'" t-field="o.name" />
                            </td>
                        </tr>
                        <tr>
                            <t t-set="inv" t-value="o.invoice_ids and o.invoice_ids[0]" />
                            <td style="width: 32%; font-weight: bold; ">
                                <span>Date&amp;nbsp; </span>
                            </td>
                            <td style="width: 2%; font-weight: bold;">
                                <span>:</span>
                            </td>
                            <td style="width: 66%;">
                                <span t-field="o.payment_date" />
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 32%; font-weight: bold;">
                                <span>Customer&amp;nbsp; </span>
                            </td>
                            <td style="width: 2%; font-weight: bold;">
                                <span>:</span>
                            </td>
                            <td style="width: 66%;">
                                <span t-field="o.partner_id" />
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 32%; font-weight: bold;">
                                <span>Guide&amp;nbsp; </span>
                            </td>
                            <td style="width: 2%; font-weight: bold;">
                                <span>:</span>
                            </td>
                            <td style="width: 66%;">
                                <span t-field="inv.guide_id" />
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 32%; font-weight: bold;">
                                <span>Ref&amp;nbsp; </span>
                            </td>
                            <td style="width: 2%; font-weight: bold;">
                                <span>:</span>
                            </td>
                            <td style="width: 66%;">
                                <span t-field="inv.ref" />
                            </td>
                        </tr>


                    </table>
                    <table style="width: 100%; margin-top:5px;">
                        <thead>
                            <tr class="border_top_black border_bottom_black" style="color: black;">
                                <th colspan="3" style="padding: 2px;">Description</th>
                                <th
                                    style="padding: 2px; text-align: right; width: 15%; white-space: nowrap;">
                                    Amount</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-foreach="o.reconciled_invoice_ids" t-as="inv">
                                <!-- Invoice reference row -->
                                <tr class="border_top_black">
                                    <td colspan="4" style="padding: 2px; font-weight: bold;">
                                        <span t-esc="inv.name or inv.ref or ''" />
                                    </td>
                                </tr>
                                <!-- Loop through invoice lines -->
                                <t t-foreach="inv.invoice_line_ids" t-as="line">
                                    <t t-if="line.display_type not in ('line_section', 'line_note')">
                                        <tr class="border_bottom_grey">
                                            <td colspan="3" style="padding: 2px;">
                                                <span
                                                    t-esc="line.name or line.product_id.name or ''" />
                                                <br />
                                                <span style="color: #000000; font-size: 8pt;"> Qty: <t
                                                        t-esc="int(line.quantity)" /> | Price: <t
                                                        t-esc="int(line.price_unit)"
                                                        t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}" />
                                                <t
                                                        t-if="line.discount > 0"> | Disc: <t
                                                            t-esc="'%g' % line.discount" />%</t></span>
                                            </td>
                                            <td class="cell_value">
                                                <span t-esc="line.price_subtotal"
                                                    t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}" />
                                            </td>
                                        </tr>
                                    </t>
                                </t>

                                <tr>
                                    <td colspan="2" />
                                    <td class="cell_value" style="font-weight: bold;">
                                        Subtotal
                                    </td>
                                    <td class="cell_value" style="font-weight: bold;">
                                        <span t-esc="inv.amount_untaxed"
                                            t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}" />
                                    </td>
                                </tr>
                            </t>
                            <tr>
                                <td height="20" colspan="4" />
                            </tr>
                            <tr class="border_top_black">
                                <td colspan="2" />
                                <td class="cell_value">
                                    <strong>Net Amount</strong>
                                </td>
                                <td class="cell_value">
                                    <span
                                        t-esc="sum(inv.amount_total for inv in o.reconciled_invoice_ids)"
                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}" />
                                </td>
                            </tr>
                            <tr>
                                <td style="width:33%;" />
                                <td colspan="2"
                                    style="width:34%; text-align: left; padding: 2px; white-space: nowrap;">
                                    <strong>Paid By: <span t-field="o.journal_id.name" /></strong>
                                </td>
                                <td />
                            </tr>
                            <tr>
                                <td style="width:33%;" />
                                <td colspan="2"
                                    style="width:34%; text-align: left; padding: 2px; white-space: nowrap;">
                                    <strong>Total Amount Paid</strong>
                                </td>
                                <td class="cell_value">
                                    <strong>
                                        <span t-field="o.amount"
                                            t-options='{"widget": "monetary", "display_currency": o.currency_id}' />
                                    </strong>
                                </td>
                            </tr>

                        </tbody>
                    </table>
                    <p class="mt16">
                        No signature is required as this is a computer generated document
                    </p>
                </div>
            </t>
        </template>


        <template id="report_receipt_with_payment_compact">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="v13_spa_ms.report_receipt_compact_document" />
                </t>
            </t>
        </template>

        <report
            id="account_receipt_compact"
            model="account.payment"
            string="Payment Receipt (Compact)"
            report_type="qweb-pdf"
            name="v13_spa_ms.report_receipt_with_payment_compact"
            file="v13_spa_ms.report_receipt_with_payment_compact"
            attachment="(object.state == 'posted') and ((object.name or 'RCP').replace('/','_')+'(Compact).pdf')"
            print_report_name="(object._get_report_base_filename())"
            paperformat="v13_spa_ms.paperformat_external_layout_customize_compact"
        />


    </data>
</odoo>