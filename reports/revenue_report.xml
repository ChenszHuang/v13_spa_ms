<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="revenue_report">
            <t t-call='web.html_container'>
                <t t-call="web.internal_layout">
                    <t t-set="report_title" t-value="'FAD4'" />
                    <div class="page">
                        <h5>Revenue Summary Report</h5>
                    </div>
                </t>
            </t>
        </template>

        <report id="action_revenue_report" model="print.revenue.report" string="Revenue Report" report_type="qweb-pdf" name="v13_spa_ms.revenue_report" file="v13_spa_ms.revenue_report" print_report_name="(object._get_report_base_filename())" menu="False" paperformat="v13_spa_ms.paperformat_internal_layout_customize" />
    </data>
</odoo>