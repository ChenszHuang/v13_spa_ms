<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="view_print_therapist_activity_report_form" model="ir.ui.view">
            <field name="name">print.therapist.activity.report.form</field>
            <field name="model">print.therapist.activity.report</field>
            <field name="arch" type="xml">
                <form string="Print Therapist Activity Report">
                    <group>
                        <group>
                            <label for="date_from" string="Date" />
                            <div class="o_row">
                                <field name="date_from" nolabel="1" class="oe_inline" />
                                <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon"
                                    title="Arrow" />
                                <field name="date_to" nolabel="1" class="oe_inline" />
                            </div>
                        </group>
                    </group>
                    <footer>
                        <button name="action_print" type="object" string="Print" class="btn-primary" />
                        <button string="Cancel" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_print_therapist_activity_report" model="ir.actions.act_window">
            <field name="name">Therapist Activity Report</field>
            <field name="res_model">print.therapist.activity.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>